# Cluster — local env template. Copy to .env.local and fill in.
# .env.local is gitignored and must NEVER be committed.
# In production, these are set via Secret Manager (firebase apphosting:secrets:set),
# NOT from this file. See project-spec.md sections 4 & 11.

# --- Firebase (browser-safe: the six NEXT_PUBLIC_FIREBASE_* values) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (SERVER-ONLY — never NEXT_PUBLIC_) ---
# Service account key as a single-line JSON string.
FIREBASE_SERVICE_ACCOUNT=

# --- Paystack ---
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# --- Sanity (read-only consumer) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
# Only if reading drafts / a private dataset. NEVER a write token.
SANITY_API_READ_TOKEN=

# --- MetaMap (KYC) ---
NEXT_PUBLIC_METAMAP_CLIENT_ID=
NEXT_PUBLIC_METAMAP_FLOW_ID=
METAMAP_CLIENT_SECRET=
METAMAP_WEBHOOK_SECRET=
